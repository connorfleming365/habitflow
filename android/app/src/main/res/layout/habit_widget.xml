<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- ── Header ── -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌊 HabitFlow"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black"/>

        <TextView
            android:id="@+id/widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 0"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-black"/>
    </LinearLayout>

    <!-- ── Progress bar ── -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginBottom="10dp"
        android:progressDrawable="@drawable/widget_progress_drawable"
        android:max="100"
        android:progress="0"/>

    <!-- ── Habit rows (up to 5) ── -->
    <LinearLayout
        android:id="@+id/habit_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">
        <TextView android:id="@+id/habit_icon_0"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/habit_name_0"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:textColor="#DDFFFFFF" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/habit_check_0"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">
        <TextView android:id="@+id/habit_icon_1"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/habit_name_1"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:textColor="#DDFFFFFF" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/habit_check_1"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">
        <TextView android:id="@+id/habit_icon_2"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/habit_name_2"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:textColor="#DDFFFFFF" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/habit_check_2"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">
        <TextView android:id="@+id/habit_icon_3"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/habit_name_3"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:textColor="#DDFFFFFF" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/habit_check_3"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/habit_row_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">
        <TextView android:id="@+id/habit_icon_4"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/habit_name_4"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:textColor="#DDFFFFFF" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/habit_check_4"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="14sp" android:gravity="center"/>
    </LinearLayout>

    <!-- ── Date footer ── -->
    <TextView
        android:id="@+id/widget_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Today"
        android:textColor="#66FFFFFF"
        android:textSize="9sp"
        android:fontFamily="sans-serif-medium"/>

</LinearLayout>
